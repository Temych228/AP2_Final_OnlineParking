{
  "uid": "online-parking-business",
  "title": "Online Parking Business Metrics",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "timezone": "browser",
  "tags": [
    "online-parking",
    "business",
    "prometheus"
  ],
  "templating": {
    "list": [
      {
        "type": "query",
        "name": "job",
        "label": "Job",
        "query": "label_values(up, job)",
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "type": "stat",
      "title": "Services Up",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "targets": [
        {
          "expr": "sum(up{job=~\"$job\"})",
          "legendFormat": "up",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "value"
      }
    },
    {
      "type": "timeseries",
      "title": "Requests per Second",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 18,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=~\"$job\"}[5m])) by (job)",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Error Rate",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=~\"$job\",status=~\"5..\"}[5m])) by (job) / sum(rate(http_requests_total{job=~\"$job\"}[5m])) by (job)",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "p95 HTTP Latency",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=~\"$job\"}[5m])) by (le, job))",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Bookings Lifecycle",
      "gridPos": {
        "x": 0,
        "y": 13,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(bookings_created_total{job=~\"$job\"}[5m]))",
          "legendFormat": "created",
          "refId": "A"
        },
        {
          "expr": "sum(rate(bookings_confirmed_total{job=~\"$job\"}[5m]))",
          "legendFormat": "confirmed",
          "refId": "B"
        },
        {
          "expr": "sum(rate(bookings_cancelled_total{job=~\"$job\"}[5m]))",
          "legendFormat": "cancelled",
          "refId": "C"
        },
        {
          "expr": "sum(rate(bookings_completed_total{job=~\"$job\"}[5m]))",
          "legendFormat": "completed",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Parking Results",
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(parking_reservations_total{job=~\"$job\"}[5m]))",
          "legendFormat": "reservations",
          "refId": "A"
        },
        {
          "expr": "sum(rate(parking_releases_total{job=~\"$job\"}[5m]))",
          "legendFormat": "releases",
          "refId": "B"
        },
        {
          "expr": "avg(parking_spots_available{job=~\"$job\"})",
          "legendFormat": "available",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Notifications",
      "gridPos": {
        "x": 0,
        "y": 21,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(notifications_sent_total{job=~\"$job\"}[5m])) by (type)",
          "legendFormat": "sent {{type}}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(notifications_failed_total{job=~\"$job\"}[5m])) by (type)",
          "legendFormat": "failed {{type}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Payments",
      "gridPos": {
        "x": 12,
        "y": 24,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(payments_created_total{job=~\"$job\"}[5m]))",
          "legendFormat": "created",
          "refId": "A"
        },
        {
          "expr": "sum(rate(payments_paid_total{job=~\"$job\"}[5m]))",
          "legendFormat": "paid",
          "refId": "B"
        },
        {
          "expr": "sum(rate(payments_cancelled_total{job=~\"$job\"}[5m]))",
          "legendFormat": "cancelled",
          "refId": "C"
        },
        {
          "expr": "sum(rate(payments_failed_total{job=~\"$job\"}[5m]))",
          "legendFormat": "failed",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Auth / User Flows",
      "gridPos": {
        "x": 0,
        "y": 29,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(auth_register_total{job=~\"$job\"}[5m]))",
          "legendFormat": "auth register",
          "refId": "A"
        },
        {
          "expr": "sum(rate(auth_login_total{job=~\"$job\"}[5m]))",
          "legendFormat": "auth login",
          "refId": "B"
        },
        {
          "expr": "sum(rate(users_created_total{job=~\"$job\"}[5m]))",
          "legendFormat": "users created",
          "refId": "C"
        },
        {
          "expr": "sum(rate(users_updated_total{job=~\"$job\"}[5m]))",
          "legendFormat": "users updated",
          "refId": "D"
        },
        {
          "expr": "sum(rate(users_verified_total{job=~\"$job\"}[5m]))",
          "legendFormat": "users verified",
          "refId": "E"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    }
  ]
}